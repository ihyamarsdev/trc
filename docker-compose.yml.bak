services:
    app:
        image: ihyamars/trc
        build:
            context: .
            dockerfile: Dockerfile
            args:
                APP_ENV: production
                APP_DEBUG: 'false'
            cache_from:
                - 'ihyamars/trc:latest'
            target: production
        container_name: trc-app
        restart: always
        env_file:
            - .env.production
        ports:
            - '8000:8000'
        volumes:
            - 'app_log_data:/app/storage/logs'
            - 'public_data:/app/storage/app/public'
        depends_on:
            database:
                condition: service_started
        healthcheck:
            test:
                - CMD-SHELL
                - 'wget --quiet --tries=1 --spider http://localhost:8000/health || exit 1'
            interval: 30s
            timeout: 5s
            retries: 3
            start_period: 10s
        deploy:
            resources:
                limits:
                    cpus: '2'
                    memory: 2G
                reservations:
                    cpus: '0.5'
                    memory: 512M
        logging:
            driver: json-file
            options:
                max-size: 10m
                max-file: '3'
    database:
        image: 'postgres:15-alpine3.22'
        container_name: trc-database
        restart: always
        environment:
            POSTGRES_USER: trc
            POSTGRES_PASSWORD: trc123
            POSTGRES_DB: trc
        ports:
            - '5432:5432'
        volumes:
            - 'db_data:/var/lib/postgresql/data'
        healthcheck:
            test:
                - CMD-SHELL
                - 'pg_isready -U trc'
            interval: 10s
            timeout: 5s
            retries: 5
        deploy:
            resources:
                limits:
                    cpus: '1'
                    memory: 1G
                reservations:
                    cpus: '0.25'
                    memory: 256M
        logging:
            driver: json-file
            options:
                max-size: 10m
                max-file: '3'
    database-admin:
        image: 'elestio/pgadmin:latest'
        restart: always
        environment:
            PGADMIN_DEFAULT_EMAIL: admin@trc.com
            PGADMIN_DEFAULT_PASSWORD: admin123
            PGADMIN_LISTEN_PORT: 7000
        ports:
            - '7000:7000'
        volumes:
            - 'admin-config:/pgadmin4/servers.json'
        deploy:
            resources:
                limits:
                    cpus: '0.5'
                    memory: 512M
volumes:
    app_log_data: null
    public_data: null
    db_data: null
    admin-config: null
    sail-mysql:
        driver: local
    sail-redis:
        driver: local
